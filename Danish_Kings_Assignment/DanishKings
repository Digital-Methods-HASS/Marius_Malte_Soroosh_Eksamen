## Calculate the duration of reign for all the kings in your table

Create a new column called  `duration` in the kings dataset, utilizing the `mutate()` function from tidyverse. Check with your group to brainstorm the options.

```{r}
# OUR CODE

kings <- kings %>% 
  mutate(Start_year = as.numeric(Start_year), End_year = as.numeric(End_year))
  
kings <- kings %>% 
  mutate(Duration = End_year - Start_year) 
  


top_3 <- sort(kings$Duration, decreasing = TRUE)[1:3]

top_3


```

## Calculate the average duration of reign for all rulers


```{r}
# OUR CODE

library(tidyverse)

# Tibble way

avg_reign <- kings %>% 
  summarize(mean_duration = mean(Duration, na.rm = TRUE))

# Vector way

avg_reign_vector <- mean(kings$Duration, na.rm = TRUE)

print(avg_reign)


```

## How many and which kings enjoyed a longer-than-average duration of reign?

```{r}
# OUR CODE


#1 Finds the kings who enjoyed a longer-than-average duration of reign
long_reigns <- kings %>% 
  filter(Duration > avg_reign_vector)
long_reigns

#2 Shows which kings enjoyed a longer-than-average duration of reign
long_reigns %>% 
  select(Name, Duration) %>% 
  arrange(desc(Duration))

# 5. Counts how many kings enjoyed a longer-than-average duration of reign
long_reigns %>% 
  count()

```

## How many days did the three longest-ruling monarchs rule? 

```{r}
# OUR CODE

top_3_monarchs <- kings %>% 
  arrange(desc(Duration)) %>%   
  slice(1:3) %>%                
  mutate(
    Days_Basic = Duration * 365,
    # To count transition/leap year we add 0.25 to the 365 days, because every fourth year is a leap year
    Days_Leap = Duration * 365.25 
  )

print(top_3_monarchs %>% select(Name, Duration, Days_Leap))

```


## Challenge: Plot the kings' duration of reign through time

```{r}
# OUR CODE

kings <- kings |>
  mutate(Midyear = Start_year + (End_year - Start_year) / 2)

ggplot(kings, aes(x = Midyear, y = Duration)) +
  geom_point() +
  geom_smooth() +
  labs(
    title = "Duration of reign of Danish monarchs through time",
    x = "Midyear of reign",
    y = "Duration of reign (years)"
  ) +
  theme_bw() +
  theme(text = element_text(size = 14))

```


